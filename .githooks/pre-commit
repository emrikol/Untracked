#!/usr/bin/env bash
# Blocks the commit unless static analysis is clean.
#
# Version-controlled rather than living in .git/hooks, and wired up with
#     git config core.hooksPath .githooks
# which scripts/install-hooks.sh does for you. A hook that only exists on one
# machine isn't a gate.
#
# What runs: scripts/check-invariants.sh — project invariants, SwiftLint
# (--strict), shellcheck, and SwiftFormat in --lint mode. All are read-only; the
# hook never rewrites your files mid-commit. If formatting is the problem, run
#     ./scripts/format.sh
# and stage the result, so the change is yours and visible rather than something
# a hook did behind your back.
#
# Compiler-level checks (strict concurrency, warnings-as-errors) belong to the
# build and are not repeated here — this hook stays fast enough to not be worth
# bypassing. `git commit --no-verify` skips it; if you find yourself reaching for
# that regularly, fix the rule instead of routing around the gate.
set -euo pipefail
cd "$(dirname "$0")/.."

RED='\033[0;31m'; GREEN='\033[0;32m'; NC='\033[0m'

if ! ./scripts/check-invariants.sh; then
    echo
    echo -e "${RED}✗ Commit blocked — static analysis is not clean.${NC}"
    echo "  Formatting issues:  ./scripts/format.sh && git add -u"
    echo "  Everything else:    fix it, or change the rule in .swiftlint.yml with a reason."
    exit 1
fi

echo -e "${GREEN}✓${NC} static analysis clean"
