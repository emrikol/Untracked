#!/usr/bin/env bash
# Refuse to push a version tag without a matching, dated CHANGELOG entry.
#
# scripts/create-release-tag.sh already checks this, but it can be bypassed by
# tagging with plain `git tag`. This hook is the backstop that catches it at the
# only moment that matters: the push that triggers the release workflow. Without
# it, a hand-made tag produces a release whose notes are the awk fallback rather
# than the changelog, and the omission is only visible after publication.
#
# Git feeds pushed refs on stdin as: <local ref> <local sha> <remote ref> <remote sha>
set -uo pipefail
cd "$(git rev-parse --show-toplevel)" || exit 1

RED='\033[0;31m'; NC='\033[0m'
fail=0

while read -r local_ref _ _ _; do
    [[ "$local_ref" == refs/tags/* ]] || continue
    tag="${local_ref#refs/tags/}"
    # Only release tags. Anything else (annotated notes, scratch tags) is free.
    [[ "$tag" =~ ^v[0-9]+\.[0-9]+\.[0-9]+(-.*)?$ ]] || continue
    version="${tag#v}"

    if [[ ! -f CHANGELOG.md ]]; then
        echo -e "${RED}✗ CHANGELOG.md not found${NC} — required to tag $tag"
        fail=1
        continue
    fi
    if ! grep -q "## \[$version\]" CHANGELOG.md; then
        echo -e "${RED}✗ No CHANGELOG entry for $version${NC}"
        echo "  Add a '## [$version] - $(date +%Y-%m-%d)' section before pushing $tag."
        fail=1
        continue
    fi
    if grep -q "## \[$version\] - TBD" CHANGELOG.md; then
        echo -e "${RED}✗ CHANGELOG entry for $version still says TBD${NC}"
        echo "  Set a real date: ## [$version] - $(date +%Y-%m-%d)"
        fail=1
        continue
    fi
    if ! grep -qE "## \[$version\] - [0-9]{4}-[0-9]{2}-[0-9]{2}" CHANGELOG.md; then
        echo -e "${RED}✗ CHANGELOG entry for $version has no valid date${NC}"
        echo "  Expected: ## [$version] - YYYY-MM-DD"
        fail=1
        continue
    fi
    echo "  ✓ CHANGELOG validated for $tag"
done

exit "$fail"
